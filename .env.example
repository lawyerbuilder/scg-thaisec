# Copy to .env.local and fill in. Vercel + Neon will populate DATABASE_URL automatically.

DATABASE_URL=

# Public URL of this deployment — used by the MCP server to build absolute detail links.
THAISEC_SITE_URL=http://localhost:3000

# Ingestion knobs (optional — defaults are reasonable)
INGEST_MAX_DOCS=500
INGEST_MAX_MINUTES=20
INGEST_REF_IDS=80,1,2,3,4
INGEST_USER_AGENT=Mozilla/5.0 (compatible; SCGThaiSECBot/0.1; +https://scg-thaisec.vercel.app)
